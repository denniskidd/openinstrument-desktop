{
  "name": "openrequest-electron",
  "productName": "OpenRequest Secure Desktop",
  "version": "1.0.6",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": {
    "name": "Dennis Kidd",
    "email": "dennis.kidd@gmail.com"
  },
  "license": "ISC",
  "description": "The OpenRequest desktop app for managing lab reservations",
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "electron-notarize": "^1.2.2"
  },
  "build": {
    "appId": "edu.jh.openrequest",
    "productName": "OpenRequest Secure Desktop",
    "afterSign": "build/notarize.js",
    "mac": {
      "target": "dmg",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "identity": "Dennis Kidd (HTBVK54EU9)"
    },
    "extraResources": [
      {
        "from": "assets/openrequest.desktop",
        "to": "openrequest.desktop"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "denniskidd",
        "repo": "openrequest-electron"
      }
    ],
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "dist/**",
      "main.js",
      "preload.js",
      "renderer/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "rpm",
        "deb"
      ],
      "category": "Utility"
    }
  },
  "dependencies": {
    "electron-log": "^5.3.4",
    "electron-updater": "^6.6.2"
  }
}
