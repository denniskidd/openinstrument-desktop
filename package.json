{
  "name": "openinstrument-desktop",
  "productName": "OpenInstrument Desktop",
  "version": "2026.4.13",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": {
    "name": "Dennis Kidd",
    "email": "dennis.kidd@gmail.com"
  },
  "license": "ISC",
  "description": "The OpenInstrument desktop app for managing lab instruments.",
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "electron-notarize": "^1.2.2"
  },
  "build": {
    "appId": "com.openinstrument",
    "productName": "OpenInstrument Desktop",
    "afterSign": "build/notarize.js",
    "mac": {
      "target": [
        "zip",
        "dmg"
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "identity": "Dennis Kidd (HTBVK54EU9)"
    },
    "extraResources": [
      {
        "from": "assets/openinstrument.desktop",
        "to": "openinstrument.desktop"
      }
    ],
    "publish": [
      {
        "provider": "github"
      }
    ],
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "dist/**",
      "main.js",
      "preload.js",
      "renderer/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "rpm",
        "deb"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    }
  }
}